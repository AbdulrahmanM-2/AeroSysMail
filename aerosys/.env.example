# ══════════════════════════════════════════════════════════════
# AeroSysMail — Environment Configuration
# Copy this file to .env and update values before deploying
# NEVER commit .env to version control
# ══════════════════════════════════════════════════════════════

# ── App ───────────────────────────────────────────────────────
NODE_ENV=production
JWT_SECRET=change-this-to-a-long-random-secret-in-production
CORS_ORIGIN=*

# ── MySQL ─────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=rootpassword
DB_NAME=aerosys
DB_USER=aerosys
DB_PASSWORD=secret
DB_PORT_EXPOSE=3306

# ── Redis ─────────────────────────────────────────────────────
REDIS_PORT_EXPOSE=6379
REDIS_PASSWORD=

# ── MinIO ─────────────────────────────────────────────────────
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio123
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ── Mail ──────────────────────────────────────────────────────
MAIL_HOSTNAME=mail.aerosys.aero
SMTP_PORT_EXPOSE=25
SUBMISSION_PORT_EXPOSE=587
IMAPS_PORT_EXPOSE=993

# ── Nginx ─────────────────────────────────────────────────────
HTTP_PORT=80
HTTPS_PORT=443
