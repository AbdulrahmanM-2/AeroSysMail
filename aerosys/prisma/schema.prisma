generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id       String  @id @default(cuid())
  email    String  @unique
  name     String
  role     String  // 'admin' | 'client'
  avatar   String?
  company  String?
  password String  // Hashed password
}

model Email {
  id       String  @id @default(cuid())
  from     String
  fromName String
  to       String
  subject  String
  body     String
  preview  String
  date     DateTime
  read     Boolean @default(false)
  starred  Boolean @default(false)
  folder   String  // 'inbox' | 'sent' | 'drafts' | 'starred' | 'important'
  avatar   String?
}

model Deal {
  id          String   @id @default(cuid())
  name        String
  company     String
  value       Float
  stage       String   // 'new_lead' | 'negotiation' | 'awaiting_signature' | 'closed'
  assignedTo  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  probability Int
}

model Invoice {
  id         String        @id @default(cuid())
  client     String
  amount     Float
  status     String        // 'paid' | 'pending' | 'overdue' | 'draft'
  dueDate    DateTime
  issuedDate DateTime
  items      InvoiceItem[]
}

model InvoiceItem {
  id          String  @id @default(cuid())
  description String
  quantity    Int
  rate        Float
  invoiceId   String
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model Client {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  company      String
  phone        String
  status       String   // 'active' | 'inactive' | 'prospect'
  totalRevenue Float    @default(0)
  deals        Int      @default(0)
  lastContact  DateTime
  avatar       String?
}

model Task {
  id          String   @id @default(cuid())
  title       String
  description String
  priority    String   // 'high' | 'medium' | 'low'
  status      String   // 'todo' | 'in_progress' | 'done'
  dueDate     DateTime
  assignedTo  String
}

model AIInsight {
  id        String   @id @default(cuid())
  message   String
  type      String   // 'optimization' | 'alert' | 'suggestion'
  timestamp DateTime @default(now())
}

model RevenueData {
  id      String @id @default(cuid())
  month   String
  revenue Float
}

model Domain {
  id              String      @id @default(cuid())
  name            String      @unique
  tld             String
  registrant      String
  registrantEmail String
  status          String      // 'active' | 'pending' | 'expired' | 'transferring' | 'suspended'
  registeredAt    DateTime
  expiresAt       DateTime
  autoRenew       Boolean     @default(true)
  locked          Boolean     @default(true)
  whoisPrivacy    Boolean     @default(true)
  nameservers     String      // Stored as JSON string array
  price           Float
  renewalPrice    Float
  dnsRecords      DNSRecord[]
}

model DNSRecord {
  id       String  @id @default(cuid())
  domainId String
  domain   Domain  @relation(fields: [domainId], references: [id], onDelete: Cascade)
  type     String  // 'A' | 'AAAA' | 'CNAME' | 'MX' | 'TXT' | 'NS' | 'SRV' | 'CAA'
  name     String
  value    String
  ttl      Int     @default(3600)
  priority Int?
  weight   Int?
  port     Int?
}

model DomainTransfer {
  id            String    @id @default(cuid())
  domainName    String
  fromRegistrar String
  toRegistrar   String
  status        String    // 'pending' | 'in_progress' | 'completed' | 'failed' | 'cancelled'
  initiatedAt   DateTime  @default(now())
  completedAt   DateTime?
  authCode      String
  clientId      String
  clientName    String
}

model DomainPricing {
  id            String  @id @default(cuid())
  tld           String  @unique
  registerPrice Float
  renewalPrice  Float
  transferPrice Float
  premium       Boolean @default(false)
  popular       Boolean @default(false)
  category      String  // 'generic' | 'country' | 'new' | 'aviation' | 'business'
}

model WHOISInfo {
  id               String   @id @default(cuid())
  domainId         String   @unique
  registrantName   String
  registrantOrg    String
  registrantEmail  String
  registrantPhone  String
  registrantAddress String
  registrantCity   String
  registrantState  String
  registrantCountry String
  registrantZip    String
  adminName        String
  adminEmail       String
  techName         String
  techEmail        String
  privacyEnabled   Boolean  @default(true)
  createdDate      DateTime
  updatedDate      DateTime
  expiryDate       DateTime
}