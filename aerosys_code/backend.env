# ═══════════════════════════════════════════════
# AeroSysMail — Environment Variables
# Copy to .env and adjust before production deploy
# ═══════════════════════════════════════════════

# API
PORT=3000
NODE_ENV=production
JWT_SECRET=aerosys-super-secret-jwt-key-change-in-production-min-32-chars
CORS_ORIGIN=http://localhost

# MySQL
DB_HOST=db
DB_PORT=3306
DB_NAME=aerosys
DB_USER=aerosys
DB_PASSWORD=secret

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# MinIO (object storage — email attachments)
MINIO_HOST=minio
MINIO_PORT=9000
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio123
MINIO_BUCKET=aerosys-attachments

# SMTP — relay through Postfix container
SMTP_HOST=postfix
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Mail domain
MAIL_DOMAIN=aerosys.aero
MAIL_FROM=noreply@aerosys.aero
